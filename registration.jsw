import { authentication } from 'wix-members-backend';
import wixData from 'wix-data';
import wixCrmBackend from 'wix-crm-backend';

/**
 * 1. Register Staff Member
 * Called from the frontend Registration Page. Creates standard Wix member and adds pending `UserRegistry` record.
 */
export async function registerStaffMember(staffName, staffEmail, supervisorEmail, password) {
    try {
        // Register the user with Wix Members but DON'T approve them yet (status stays pending)
        const registrationResult = await authentication.register(staffEmail, password, {
            contactInfo: {
                firstName: staffName.split(' ')[0],
                lastName: staffName.split(' ').slice(1).join(' ') || ''
            },
            privacyStatus: 'PRIVATE'
        });

        // Add to UserRegistry database with Pending Status
        const newRecord = {
            title: staffName,
            email: staffEmail,
            supervisorEmail: supervisorEmail,
            status: "Pending Confirmation" // Awaiting staff own email confirmation
        };

        const insertedRecord = await wixData.insert("UserRegistry", newRecord);

        // Send Email Confirmation to Staff
        await sendStaffConfirmationEmail(insertedRecord._id, staffEmail, staffName);

        return { success: true, user: insertedRecord };
    } catch (error) {
        console.error("Registration Error:", error);
        return { success: false, error: error.message };
    }
}

